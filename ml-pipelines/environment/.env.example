# ============================================================================
# ML Pipelines — Environment Configuration
# ============================================================================
#
# HOW TO USE:
#   1. Copy this file to .env in the same folder:
#        cp .env.example .env
#
#   2. Replace the placeholder values below with your actual credentials.
#
#   3. The .env file is gitignored — your credentials will NOT be committed.
#
# WHEN IS THIS NEEDED?
#   - When running notebooks standalone in Jupyter / VS Code
#   - NOT needed when the backend runs notebooks via the API (it injects
#     DATABASE_URL automatically via nbconvert)
#
# HOW IT WORKS:
#   Each notebook uses python-dotenv to search for this .env file on startup.
#   If DATABASE_URL is already set in the shell environment, dotenv will NOT
#   override it (so the backend's injected value always takes priority).
#
# ============================================================================

# PostgreSQL connection string
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/intex
